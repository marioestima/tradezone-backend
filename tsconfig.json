{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",          // mantém NodeNext
    "moduleResolution": "NodeNext", // 🔹 importante
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
